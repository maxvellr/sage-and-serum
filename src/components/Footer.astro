---
const links = [
  { href: '/sage-and-serum/', label: 'Home' },
  { href: '/sage-and-serum/about', label: 'About' },
  { href: '/sage-and-serum/menu', label: 'Services' },
  { href: '/sage-and-serum/location', label: 'Location' },
  { href: '/sage-and-serum/affiliates', label: 'Affiliates' },
]
---

<footer class="bg-sage-dark text-cream py-16">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-12">

    <!-- Brand — last on mobile, first on desktop -->
    <div class="space-y-2 order-last md:order-first">
      <img
        src="/sage-and-serum/images/script-white.png"
        alt="Sage & Serum"
        class="h-9 ml-[-4px] w-auto"
      />
      <p class="font-body text-xs text-cream/30">© 2025 Sage & Serum LLC. All rights reserved.</p>
    </div>

    <!-- Nav links -->
    <div>
      <p class="font-body text-xs uppercase tracking-[0.25em] text-sage-mid mb-6">Navigation</p>
      <ul class="space-y-3 grid md:grid-cols-2">
        {links.map(link => (
          <li>
            <a href={link.href} class="font-body text-sm text-cream/70 hover:text-cream transition-colors">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div>
      <p class="font-body text-xs uppercase tracking-[0.25em] text-sage-mid mb-6">Get In Touch</p>
      <div class="space-y-3 font-body text-sm text-cream/70">
        <p>San Clemente, CA</p>
        <a href="tel:9494165125" class="block hover:text-cream transition-colors">
          Call or Text: 949-416-5125
        </a>
      </div>
    </div>

  </div>
</footer>