---
const links = [
  // { href: '/sage-and-serum/', label: 'Home' },
  { href: '/sage-and-serum/menu', label: 'Services' },
  { href: '/sage-and-serum/about', label: 'About' },
  { href: '/sage-and-serum/location', label: 'Location' },
  { href: '/sage-and-serum/affiliates', label: 'Affiliates' },
]
---

<nav class="fixed top-0 w-full z-50 bg-cream/95 backdrop-blur-sm border-b border-sage-mid/30">
  <div class="max-w-6xl mx-auto px-6 py-4 grid grid-cols-3 items-center">

  <!-- Logo left -->
  <a href="/sage-and-serum/" class="flex items-center">
    <img
      src="/sage-and-serum/images/logo-crop.png"
      alt="Sage & Serum"
      class="h-9 pt-1 w-auto"
    />
  </a>

  <!-- Links center -->
  <ul class="hidden md:flex items-center justify-center gap-8">
    {links.map(link => (
      <li>
        <a href={link.href} class="font-body text-sm text-navy/60 hover:text-navy transition-colors tracking-wide">
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Empty right col to balance -->
  <div class="hidden md:block" />

  <!-- Hamburger (mobile only) -->
  <div class="md:hidden flex justify-end col-start-3">
    <button
      id="menu-toggle"
      class="flex flex-col gap-1 p-2 outline-none focus:outline-none"
      aria-label="Toggle menu"
    >
      <span class="hamburger-line block w-5 h-px bg-navy transition-all duration-300" />
      <span class="hamburger-line block w-5 h-px bg-navy transition-all duration-300" />
      <span class="hamburger-line block w-5 h-px bg-navy transition-all duration-300" />
    </button>
  </div>

</div>

  <div
    id="mobile-menu"
    class="md:hidden hidden flex-col px-6 pb-6 pt-2 bg-cream/95 backdrop-blur-sm border-t border-sage-mid/20"
  >
    <ul class="space-y-4">
      {links.map(link => (
        <li>
          <a href={link.href} class="font-body text-sm text-navy/60 hover:text-navy transition-colors tracking-wide block py-1">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  const lines = document.querySelectorAll('.hamburger-line')

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')
    if (isOpen) {
      menu?.classList.add('hidden')
      menu?.classList.remove('flex')
      lines[0].style.transform = ''
      lines[1].style.opacity = '1'
      lines[2].style.transform = ''
    } else {
      menu?.classList.remove('hidden')
      menu?.classList.add('flex')
      lines[0].style.transform = 'translateY(5px) rotate(45deg)'
      lines[1].style.opacity = '0'
      lines[2].style.transform = 'translateY(-5px) rotate(-45deg)'
    }
  })

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      menu.classList.remove('flex')
      lines[0].style.transform = ''
      lines[1].style.opacity = '1'
      lines[2].style.transform = ''
    })
  })
</script>