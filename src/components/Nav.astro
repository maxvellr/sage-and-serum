
---
const base = import.meta.env.BASE_URL

const links = [
  { href: `${base}`, label: 'Home' },
  { href: `${base}/about`, label: 'About' },
  { href: `${base}/menu`, label: 'Services' },
  { href: `${base}/location`, label: 'Location & Hours' },
  { href: `${base}/affiliates`, label: 'Affiliates' },
]
---

<nav class="fixed top-0 w-full z-50 bg-cream/90 backdrop-blur-sm border-b border-sage/20">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">

    <a href="/" class="font-display text-2xl text-navy italic tracking-wide">
      Sage & Serum
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <li>
          <a href={link.href} class="font-body text-sm text-navy/70 hover:text-navy transition-colors tracking-wide">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="#book" class="hidden md:block bg-sage text-cream text-sm font-body px-5 py-2 rounded-full hover:bg-navy transition-colors">
      Book Now
    </a>

    <!-- Hamburger -->
    <button
    id="menu-toggle"
    class="md:hidden flex flex-col gap-1 p-2 outline-none focus:outline-none"
    aria-label="Toggle menu"
    >
    <span class="hamburger-line block w-5 h-px bg-navy transition-all duration-300" />
    <span class="hamburger-line block w-5 h-px bg-navy transition-all duration-300" />
    <span class="hamburger-line block w-5 h-px bg-navy transition-all duration-300" />
    </button>

  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden flex-col px-6 pb-6 pt-2 bg-cream/95 backdrop-blur-sm border-t border-sage/10"
  >
    <ul class="space-y-4 mb-6">
      {links.map(link => (
        <li>
          <a href={link.href} class="font-body text-sm text-navy/70 hover:text-navy transition-colors tracking-wide block py-1">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a href="#book" class="bg-sage text-cream text-sm font-body px-5 py-2.5 rounded-full hover:bg-navy transition-colors text-center">
      Book Now
    </a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  const lines = document.querySelectorAll('.hamburger-line')

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden')

    if (isOpen) {
        menu?.classList.add('hidden')
        menu?.classList.remove('flex')
        lines[0].style.transform = ''
        lines[1].style.opacity = '1'
        lines[2].style.transform = ''
    } else {
        menu?.classList.remove('hidden')
        menu?.classList.add('flex')
        lines[0].style.transform = 'translateY(5px) rotate(45deg)'
        lines[1].style.opacity = '0'
        lines[2].style.transform = 'translateY(-5px) rotate(-45deg)'
    }
  })

  // Close menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden')
      menu.classList.remove('flex')
      lines[0].style.transform = ''
      lines[1].style.opacity = '1'
      lines[2].style.transform = ''
    })
  })
</script>