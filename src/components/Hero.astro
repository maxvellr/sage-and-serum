<section class="min-h-screen flex items-center bg-cream pt-16 md:pt-20">
  <div class="max-w-6xl mx-auto px-6 md:py-20 py-16 grid md:grid-cols-2 gap-12 items-center">

    <!-- Text -->
    <div class="space-y-6">
      <p class="font-body text-xs uppercase tracking-[0.25em] text-teal">
        Esthetics & Skin Care
      </p>
      <h1 class="font-display text-6xl lg:text-7xl text-navy leading-tight">
        Skin that feels <em>as good</em> as it looks.
      </h1>
      <p class="font-body text-base text-navy/60 leading-relaxed max-w-md">
        Sage & Serum is a boutique esthetics studio offering personalized skin care
        rooted in clean ingredients and genuine care.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <a href="#book" class="bg-teal text-cream font-body text-sm px-6 py-3 rounded-full hover:bg-teal-dark transition-colors">
          Book a Service
        </a>
        <a href="/sage-and-serum/menu" class="border border-teal text-navy font-body text-sm px-6 py-3 rounded-full hover:bg-teal/10 transition-colors">
          View Services
        </a>
      </div>
    </div>

    <!-- Placeholder image -->
    <div class="relative">
      <div class="aspect-[4/5] rounded-3xl bg-blush/40 overflow-hidden">
        <img
          src="https://images.unsplash.com/photo-1592296429945-93008c7e5a59?q=80&w=2346&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
          alt="Sage & Serum studio"
          class="w-full h-full object-cover opacity-80"
        />
      </div>
      <!-- Floating accent card -->
      <div class="absolute -bottom-4 -left-4 bg-cream border border-blush rounded-2xl px-5 py-4 shadow-sm">
        <p class="font-display text-lg text-navy italic">Clean & Effective</p>
      </div>
    </div>

  </div>
</section>