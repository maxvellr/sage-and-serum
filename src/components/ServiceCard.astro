---
const { title, description, duration } = Astro.props
---

<div class="bg-cream rounded-2xl p-6 flex flex-col gap-4 border border-silver hover:border-sage-mid transition-colors">
  <div class="w-10 h-10 rounded-full bg-blush/60 flex items-center justify-center">
    <span class="w-3 h-3 rounded-full bg-teal block" />
  </div>
  <div class="flex-1">
    <h3 class="font-display text-xl text-navy mb-2">{title}</h3>
    <p class="font-body text-sm text-navy/60 leading-relaxed">{description}</p>
  </div>
  <p class="font-body text-xs text-teal tracking-wide">{duration}</p>
</div>