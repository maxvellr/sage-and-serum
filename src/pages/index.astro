---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Home">
  <main class="relative min-h-screen flex flex-col items-center justify-center bg-cream px-6 text-center overflow-hidden">

    <!-- Leaf background -->
    <img
      src="/images/leaf-background.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover mix-blend-multiply pointer-events-none"
    />

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center">

      <!-- Script logo -->
      <div class="w-full max-w-sm mb-3">
        <img
          src="/images/logo-crop.png"
          alt="Sage & Serum"
          class="w-full h-auto"
        />
      </div>

      <!-- Pill -->
      <div class="mb-4">
        <img
          src="/images/logo-pill.png"
          alt="Essential Skin Studio"
          class="h-7 w-auto mx-auto"
        />
      </div>
<a
  href="/menu"
  class="border border-navy/20 text-navy/50 font-body text-xs px-6 py-2 rounded-full hover:border-navy/40 hover:text-navy transition-colors tracking-widest uppercase"
  >
  View Services
</a>

    </div>

  </main>
</BaseLayout>