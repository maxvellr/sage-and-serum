---
import BaseLayout from '../layouts/BaseLayout.astro'
import ServiceCard from '../components/ServiceCard.astro'

const services = [
  {
    title: 'Spray Tan',
    description: 'A flawless, natural looking tan formulated to match all skin tones.',
    duration: '$75',
  },
]
---

<BaseLayout title="Spray Tan">
  <main class="pt-20 pb-24">

    <!-- Full width banner -->
    <!-- <div class="w-full h-96 overflow-hidden mb-12">
      <img
        src="/sage-and-serum/images/spray_room.jpg"
        alt="Spray Tan Room at Sage & Serum"
        class="w-full h-full object-cover object-center"
      />
    </div> -->

    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-8">
        <h1 class="font-display text-6xl text-navy mb-6">Spray Tan</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          A flawless, natural looking tan formulated to match all skin tones. Book your appointment today.
        </p>
      </div>

      <!-- Summer Special -->
      <div class="my-8 bg-sage-warm/20 rounded-3xl p-8 border border-sage-warm/40">
        <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-3">Limited Time Offer</p>
        <h3 class="font-display text-3xl text-navy mb-2">Summer Spray Tan Special</h3>
        <p class="font-body text-sm text-navy/60 leading-relaxed max-w-xl">
          Now through August 1, 2026 — $65. Regular price $75.
        </p>
      </div>

      <!-- Services -->
      <div class="space-y-16">
        <div>
          <div class="flex items-center gap-4 mb-8">
            <div class="w-8 h-px bg-teal" />
            <h2 class="font-display text-3xl text-navy">Services</h2>
          </div>
          <div class="grid sm:grid-cols-2 gap-6">
            {services.map(s => (
              <ServiceCard title={s.title} description={s.description} duration={s.duration} />
            ))}
          </div>
        </div>
      </div>

      <!-- Prep tips -->
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-8 h-px bg-teal" />
          <h2 class="font-display text-3xl text-navy">How to Prepare</h2>
        </div>
        <a
          href="/sage-and-serum/spray-tan-prep.pdf"
          target="_blank"
          class="inline-flex items-center gap-2 font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4 mb-8 block"
        >
          Download our Spray Tan Glow Guide →
        </a>
        <div class="grid sm:grid-cols-3 gap-6">
          {[
            { title: 'Exfoliate', description: 'Exfoliate your skin 24 hours before your appointment for the most even, long-lasting result.', duration: '24 hrs before' },
            { title: 'Come Clean', description: 'Arrive with clean, dry skin — free of moisturizer, deodorant, and makeup.', duration: 'Day of' },
            { title: 'Wear Loose Clothing', description: 'Bring or wear loose, dark clothing to your appointment to avoid transfer.', duration: 'Day of' },
          ].map(s => (
            <ServiceCard title={s.title} description={s.description} duration={s.duration} />
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-8 bg-cream rounded-3xl p-10 border border-silver">
        <p class="font-body text-sm text-navy/60">
          All services are by appointment only — please call or text Dawn to schedule at
          <a href="tel:9494165125" class="text-teal hover:text-navy transition-colors">949-416-5125</a>.
        </p>
      </div>

    </div>
  </main>
</BaseLayout>