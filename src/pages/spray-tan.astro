---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Spray Tan">
  <main class="pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-16">
        <h1 class="font-display text-6xl text-navy mb-6">Spray Tan</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          A flawless, natural looking tan formulated to match all skin tones. Book your appointment today.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-16 items-start mb-16">

        <!-- Room photo placeholder -->
        <div class="aspect-[4/3] rounded-3xl bg-blush/40 overflow-hidden border border-silver">
          <img
            src="https://placehold.co/800x600/E4DBD2/2D4A52?text=Spray+Tan+Room"
            alt="Spray Tan Room"
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Service details -->
        <div class="space-y-8">

          <!-- Standard -->
          <div class="bg-cream rounded-2xl p-6 border border-silver">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-display text-2xl text-navy">Spray Tan</h3>
              <span class="font-body text-sm text-teal whitespace-nowrap">$75</span>
            </div>
            <p class="font-body text-sm text-navy/60 leading-relaxed">
              A flawless, natural looking tan formulated to match all skin tones.
            </p>
          </div>

          <!-- Summer Special -->
          <div class="bg-sage-warm/20 rounded-2xl p-6 border border-sage-warm/40">
            <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-3">Limited Time</p>
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-display text-2xl text-navy">Summer Spray Tan Special</h3>
              <span class="font-body text-sm text-teal whitespace-nowrap">$65</span>
            </div>
            <p class="font-body text-sm text-navy/60 leading-relaxed">
              Now through August 1, 2026.
            </p>
          </div>

          <!-- CTA -->
          <div class="pt-2">
            <!-- <a
              href="tel:9494165125"
              class="inline-block bg-teal text-cream font-body text-sm px-8 py-3 rounded-full hover:bg-teal-dark transition-colors"
            >
              Call or Text to Book
            </a> -->
            <p class="font-body text-right text-xs text-navy/40 mt-3">By appointment only — call or text Dawn at 949-416-5125.</p>
          </div>

        </div>
      </div>

      <!-- Prep tips -->
      <!-- <div class="bg-cream rounded-3xl p-10 border border-silver">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-8 h-px bg-teal" />
          <h2 class="font-display text-3xl text-navy">How to Prepare</h2>
        </div>
        <div class="grid sm:grid-cols-3 gap-8">
          {[
            { heading: 'Exfoliate', body: 'Exfoliate your skin 24 hours before your appointment for the most even, long-lasting result.' },
            { heading: 'Come Clean', body: 'Arrive with clean, dry skin — free of moisturizer, deodorant, and makeup.' },
            { heading: 'Wear Loose Clothing', body: 'Bring or wear loose, dark clothing to your appointment to avoid transfer.' },
          ].map(tip => (
            <div class="space-y-3">
              <div class="w-8 h-px bg-teal" />
              <h3 class="font-display text-xl text-navy">{tip.heading}</h3>
              <p class="font-body text-sm text-navy/60 leading-relaxed">{tip.body}</p>
            </div>
          ))}
        </div>
      </div>

    </div> -->
  </main>
</BaseLayout>