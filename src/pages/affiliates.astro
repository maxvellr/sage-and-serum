---
import BaseLayout from '../layouts/BaseLayout.astro'

const skincare = [
  {
    name: 'Nelly De Vuyst',
    description: '<p>A European skincare line rooted in botanical ingredients and clean formulations. Nelly De Vuyst products are results-driven, EcoCert certified, and used exclusively in Sage & Serum facial treatments.</p>',
    url: '#',
  },
]

const makeup = [
  {
    name: 'Ilia',
    description: '<p>Clean, skin-forward makeup that blurs the line between skincare and beauty.</p>',
    url: 'https://iliabeauty.com',
  },
  {
    name: 'RMS Beauty',
    description: '<p>Organic, raw, food-grade ingredients in every product — makeup that nourishes as it beautifies.</p>',
    url: 'https://rmsbeauty.com',
  },
  {
    name: 'Merit',
    description: '<p>Minimalist, clean formulas designed for an effortless, everyday routine.</p>',
    url: 'https://meritsociety.com',
  },
]

const luxury = [
  {
    name: 'Morgan Mabry — Makeup Artist',
    image: '/images/morgan-mabry.png',
    description: `<p>A sought-after makeup artist with over 20 years of experience, Morgan Mabry brings an impressive New York City career and standout portfolio of credits to her work in natural, elevated beauty for on-camera, special events, and luxury bridal.</p><p>Based in Southern California and available for travel, Morgan creates fresh, radiant looks while delivering a calm, fun and positive client experience.</p>`,
    url: 'https://www.morganmabrymakeup.com',
    isGilly: false,
  },
  {
    name: 'Gilly Louise Designs',
    image: '/images/gilly-bag.JPEG',
    description: `<p>Handmade in California — Feminine by Nature, Fabulously Girly by Design.</p><p>Gilly Louise Designs did a collab with Sage & Serum. Shop her beautiful handmade makeup bags and accessories.</p>`,
    etsy: '#',
    instagram: '#',
    isGilly: true,
  },
]
---

<BaseLayout title="Affiliates">
  <main class="pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-16">
        <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-4">Trusted Brands</p>
        <h1 class="font-display text-6xl text-navy mb-6">Affiliates & Favorites</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          Everything listed here is something used and believed in — products and brands that align with the Sage & Serum commitment to clean skincare. Some links are affiliate links, which means a small commission may be earned at no extra cost to you.
        </p>
      </div>

      <!-- LightStim callout -->
      <div class="bg-silver/30 rounded-2xl p-6 border border-silver flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-16">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.2em] text-teal mb-1">In Studio</p>
          <h3 class="font-display text-2xl text-navy mb-1">LightStim Pro Panel</h3>
          <p class="font-body text-sm text-navy/60">LED red light therapy used in every applicable treatment at Sage & Serum.</p>
        </div>
        <a
          href="https://www.lightstim.com"
          target="_blank"
          class="font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4 whitespace-nowrap"
        >
          Learn more →
        </a>
      </div>

      <!-- Skincare -->
      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-8 h-px bg-teal" />
          <h2 class="font-display text-3xl text-navy">Skincare</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {skincare.map(a => (
            <div class="bg-cream rounded-2xl p-6 flex flex-col gap-4 border border-silver hover:border-sage-mid transition-colors">
              <h3 class="font-display text-2xl text-navy">{a.name}</h3>
              <div class="font-body text-sm text-navy/60 leading-relaxed flex-1 space-y-3" set:html={a.description} />
              <a href={a.url} target="_blank" class="font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4">
                Shop now →
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Makeup -->
      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-8 h-px bg-teal" />
          <h2 class="font-display text-3xl text-navy">Makeup — Favorites</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {makeup.map(a => (
            <div class="bg-cream rounded-2xl p-6 flex flex-col gap-4 border border-silver hover:border-sage-mid transition-colors">
              <h3 class="font-display text-2xl text-navy">{a.name}</h3>
              <div class="font-body text-sm text-navy/60 leading-relaxed flex-1 space-y-3" set:html={a.description} />
              <a href={a.url} target="_blank" class="font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4">
                Shop now →
              </a>
            </div>
          ))}
        </div>
      </div>

      <!-- Luxury Beauty -->
      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-8 h-px bg-teal" />
          <h2 class="font-display text-3xl text-navy">Luxury Beauty — Favorites</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {luxury.map((a, i) => (
            <div
              class="bg-cream rounded-2xl overflow-hidden flex flex-col border border-silver hover:border-sage-mid transition-colors cursor-pointer"
              data-modal={`modal-${i}`}
              onclick={`document.getElementById('modal-${i}').classList.remove('hidden')`}
            >
              {a.image && (
                <div class="h-48 overflow-hidden">
                  <img
                    src={a.image}
                    alt={a.name}
                    class="w-full h-full object-cover object-center"
                  />
                </div>
              )}
              <div class="p-6 flex flex-col gap-3 flex-1">
                <h3 class="font-display text-2xl text-navy">{a.name}</h3>
                <div class="font-body text-sm text-navy/60 leading-relaxed line-clamp-3" set:html={a.description} />
                <p class="font-body text-xs text-teal mt-auto">Read more →</p>
              </div>
            </div>

            <!-- Modal -->
            <div
              id={`modal-${i}`}
              class="hidden fixed inset-0 z-50 flex items-center justify-center px-6"
              onclick="this.classList.add('hidden')"
            >
              <div class="absolute inset-0 bg-navy/40 backdrop-blur-sm" />
              <div
                class="relative bg-cream rounded-3xl max-w-lg w-full overflow-hidden shadow-xl"
                onclick="event.stopPropagation()"
              >
                {a.image && (
                  <div class="h-56 overflow-hidden">
                    <img
                      src={a.image}
                      alt={a.name}
                      class="w-full h-full object-cover object-center"
                    />
                  </div>
                )}
                <div class="p-8 space-y-4">
                  <div class="flex items-start justify-between gap-4">
                    <h3 class="font-display text-3xl text-navy">{a.name}</h3>
                    <button
                      class="text-navy/40 hover:text-navy transition-colors text-xl leading-none mt-1"
                      onclick={`document.getElementById('modal-${i}').classList.add('hidden')`}
                    >
                      ✕
                    </button>
                  </div>
                  <div class="font-body text-sm text-navy/60 leading-relaxed space-y-3" set:html={a.description} />
                  {a.isGilly ? (
                    <div class="flex gap-4 pt-2">
                      <a href={a.etsy} target="_blank" class="font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4">
                        Shop Etsy →
                      </a>
                      <a href={a.instagram} target="_blank" class="font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4">
                        Instagram →
                      </a>
                    </div>
                  ) : (
                    <a href={a.url} target="_blank" class="inline-block font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4 pt-2">
                      Visit site →
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Disclosure -->
      <div class="border-t border-silver pt-10">
        <p class="font-body text-xs text-navy/40 max-w-2xl leading-relaxed">
          Disclosure: Some links on this page are affiliate links. Sage & Serum may earn a small commission if you purchase through these links. This never influences which products are recommended — only brands that are trusted make this list.
        </p>
      </div>

    </div>
  </main>
</BaseLayout>