---
import BaseLayout from '../layouts/BaseLayout.astro'

const affiliates = [
  {
    name: '[Brand Name]',
    description: 'Product description here.',
    category: 'Skincare',
    url: '#',
  },
  {
    name: '[Brand Name]',
    description: 'Product description here.',
    category: 'Makeup',
    url: '#',
  },
  {
    name: '[Brand Name]',
    description: 'Product description here.',
    category: 'Tools & Devices',
    url: '#',
  },
]
---

<BaseLayout title="Affiliates">
  <main class="pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-16">
        <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-4">Trusted Brands</p>
        <h1 class="font-display text-6xl text-navy mb-6">Affiliates & Favorites</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          Everything listed here is something used and believed in. Some links are affiliate links, which means a small commission may be earned at no extra cost to you.
        </p>
      </div>

      <!-- LightStim callout -->
      <div class="bg-silver/30 rounded-2xl p-6 border border-silver flex flex-col md:flex-row items-start md:items-center justify-between gap-4 mb-12">
        <div>
          <p class="font-body text-xs uppercase tracking-[0.2em] text-teal mb-1">In Studio</p>
          <h3 class="font-display text-2xl text-navy mb-1">LightStim Pro Panel</h3>
          <p class="font-body text-sm text-navy/60">The LED light therapy device used in every applicable treatment at Sage & Serum.</p>
        </div>
        <a
          href="https://www.lightstim.com"
          target="_blank"
          class="font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4 whitespace-nowrap"
        >
          Learn more →
        </a>
      </div>

      <!-- Cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
        {affiliates.map(a => (
          <div class="bg-cream rounded-2xl p-6 flex flex-col gap-4 border border-silver hover:border-sage-mid transition-colors">
            <div>
              <span class="font-body text-xs uppercase tracking-[0.2em] text-teal">{a.category}</span>
            </div>
            <div class="flex-1 space-y-2">
              <h3 class="font-display text-2xl text-navy">{a.name}</h3>
              <p class="font-body text-sm text-navy/60 leading-relaxed">{a.description}</p>
            </div>
            <a
              href={a.url}
              target="_blank"
              class="inline-block font-body text-sm text-teal hover:text-navy transition-colors underline underline-offset-4"
            >
              Shop now →
            </a>
          </div>
        ))}
      </div>

      <!-- Disclosure -->
      <div class="border-t border-silver pt-10">
        <p class="font-body text-xs text-navy/40 max-w-2xl leading-relaxed">
          Disclosure: Some links on this page are affiliate links. Sage & Serum may earn a small commission if you purchase through these links. This never influences which products are recommended, only brands that are trusted make this list.
        </p>
      </div>

    </div>
  </main>
</BaseLayout>