---
import BaseLayout from '../layouts/BaseLayout.astro'
import ServiceCard from '../components/ServiceCard.astro'

const categories = [
  {
    name: 'Facials',
    services: [
      {
        title: 'Essential Facial',
        description: 'Cleanse, exfoliate, extract (if needed), scalp massage, mask, serums and SPF to finish.',
        duration: '60 min — $130',
      },
      {
        title: 'Pregnancy Facial',
        description: 'Cleanse, light exfoliation using brush technique, extractions (if needed), cream mask, cream to finish.',
        duration: '60 min — $130',
      },
      {
        title: 'Organic Facial',
        description: 'Cleanse, exfoliate or AHA peel, extract (if needed), facial massage, mask, serums and SPF to finish.',
        duration: '75 min — $150',
      },
      {
        title: 'Beyond Essential Facial',
        description: 'Cleanse, exfoliate or AHA peel, extract (if needed), LED red light therapy, facial massage, sheet mask or cream mask, under eye treatment, serums and SPF to finish.',
        duration: '90 min — $175',
      },
    ]
  },
  {
    name: 'Advanced Treatments',
    services: [
      {
        title: 'LED Light Therapy',
        description: 'LightStim Pro Panel for anti-aging. Can be a stand alone treatment or add on to any facial.',
        duration: 'Add-on — $40',
      },
    ]
  },
]
---

<BaseLayout title="Services">
  <main class="pt-20 pb-24">

    <!-- Full width banner -->
    <div class="w-full h-96 overflow-hidden mb-12">
      <img
        src="/images/facial_room.jpg"
        alt="Facial Room at Sage & Serum"
        class="w-full h-full object-cover object-center"
      />
    </div>

    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-8">
        <h1 class="font-display text-6xl text-navy mb-6">Facial Menu</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          Every service at Sage & Serum is built around your needs.
          Browse the menu below and reach out with any questions before booking.
        </p>
      </div>

      <!-- Facial Special -->
      <div class="my-8 bg-sage-warm/20 rounded-3xl p-8 border border-sage-warm/40">
        <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-3">Limited Time Offer</p>
        <h3 class="font-display text-3xl text-navy mb-2">Facial Special</h3>
        <p class="font-body text-sm text-navy/60 leading-relaxed max-w-xl">
          Now through June 30, 2026 — add LightStim LED Light Therapy to any facial, a $40 value. Exclusions may apply.
        </p>
      </div>

      <!-- Categories -->
      <div class="space-y-16">
        {categories.map(cat => (
          <div>
            <div class="flex items-center gap-4 mb-8">
              <div class="w-8 h-px bg-teal" />
              <h2 class="font-display text-3xl text-navy">{cat.name}</h2>
            </div>
            <div class="grid sm:grid-cols-2 gap-6">
              {cat.services.map(s => (
                <ServiceCard title={s.title} description={s.description} duration={s.duration} />
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="mt-8 bg-cream rounded-3xl p-10 border border-silver">
        <p class="font-body text-sm text-navy/60">
          All services are by appointment only — please call or text Dawn to schedule at
          <a href="tel:9494165125" class="text-teal hover:text-navy transition-colors">949-416-5125</a>.
        </p>
      </div>

    </div>
  </main>
</BaseLayout>