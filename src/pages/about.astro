---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="About">
  <main class="pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-16">
        <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-4">Our Story</p>
        <h1 class="font-display text-6xl text-navy mb-6">About Sage & Serum</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          Sage & Serum was born from a belief that skincare should feel as good as it performs.
          Grounded in clean formulations and tailored to the individual, Sage & Serum is a boutique esthetics studio designed for care.
        </p>
      </div>

      <!-- Two col: image + bio -->
      <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
        <div class="aspect-[3/4] rounded-3xl bg-blush/40 overflow-hidden">
          <img
            src="https://placehold.co/600x800/E4DBD2/2B4658?text=Photo"
            alt="Esthetician"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="space-y-6">
          <h2 class="font-display text-4xl text-navy">Hi, I'm <em>Dawn</em></h2>
          <p class="font-body text-sm text-navy/60 leading-relaxed">
            Licensed esthetician and founder of Sage & Serum.
          </p>
          <p class="font-body text-sm text-navy/60 leading-relaxed">
            My approach is slow, intentional, and always personal. I strive on curating the perfect environment for you to relax and reconnect with yourself.
          </p>
          <div class="pt-2 flex flex-wrap gap-3">
            {['Licensed Esthetician', 'EcoCert Trained', 'Clean Beauty Advocate'].map(tag => (
              <span class="font-body text-xs text-teal border border-teal/30 rounded-full px-4 py-1.5">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>

      <!-- Values strip -->
      <div class="grid sm:grid-cols-3 gap-8 border-t border-sage-mid/30 pt-16">
        {[
          { heading: 'Clean Ingredients', body: 'Every product used in the studio meets strict clean beauty standards — effective, safe, and kind to the skin.' },
          { heading: 'Personalized Care', body: 'No two skins are alike. Every treatment starts with a thorough consultation to understand your unique needs.' },
          { heading: 'A Calm Space', body: 'The studio is designed to be a genuine retreat — quiet, unhurried, and entirely focused on you.' },
        ].map(v => (
          <div class="space-y-3">
            <div class="w-8 h-px bg-teal" />
            <h3 class="font-display text-2xl text-navy">{v.heading}</h3>
            <p class="font-body text-sm text-navy/60 leading-relaxed">{v.body}</p>
          </div>
        ))}
      </div>

    </div>
  </main>
</BaseLayout>