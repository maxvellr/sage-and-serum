---
import BaseLayout from '../layouts/BaseLayout.astro'

const photos = [
  { src: '/images/dawn.JPEG', alt: 'Dawn Kratofil' },
  { src: '/images/dawn_mike.JPEG', alt: 'Dawn and Mike' },
]
---

<BaseLayout title="About">
  <main class="pt-28 pb-24">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Header -->
      <div class="max-w-2xl mb-16">
        <p class="font-body text-xs uppercase tracking-[0.25em] text-teal mb-4">Our Story</p>
        <h1 class="font-display text-6xl text-navy mb-6">About Sage & Serum</h1>
        <p class="font-body text-base text-navy/60 leading-relaxed">
          Sage & Serum was inspired by the belief that skin health and wellness should be accessible to everybody. Rooted in clean, sustainable, results oriented, certified skincare and tailored to each individual, Sage & Serum is an inclusive skin care studio curated to genuinely care for you.
        </p>
      </div>

      <!-- Two col: carousel + bio -->
      <div class="grid md:grid-cols-2 gap-16 items-start mb-16">

        <!-- Carousel -->
        <div class="relative aspect-[3/4] rounded-3xl overflow-hidden bg-blush/40">
          {photos.map((photo, i) => (
            <div
              id={`slide-${i}`}
              class={`absolute inset-0 transition-opacity duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0'}`}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                class="w-full h-full object-cover object-top"
              />
            </div>
          ))}

          <!-- Prev button -->
          <button
            id="prev"
            class="absolute left-3 top-1/2 -translate-y-1/2 bg-cream/80 hover:bg-cream transition-colors rounded-full w-8 h-8 flex items-center justify-center text-navy shadow-sm"
            aria-label="Previous photo"
          >
            ‹
          </button>

          <!-- Next button -->
          <button
            id="next"
            class="absolute right-3 top-1/2 -translate-y-1/2 bg-cream/80 hover:bg-cream transition-colors rounded-full w-8 h-8 flex items-center justify-center text-navy shadow-sm"
            aria-label="Next photo"
          >
            ›
          </button>

          <!-- Dots -->
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
            {photos.map((_, i) => (
              <button
                class={`dot w-2 h-2 rounded-full transition-colors ${i === 0 ? 'bg-navy' : 'bg-navy/30'}`}
                data-index={i}
                aria-label={`Go to photo ${i + 1}`}
              />
            ))}
          </div>
        </div>

        <!-- Bio -->
        <div class="space-y-5">
          <p class="font-body text-sm text-navy/60 leading-relaxed">
            Born and raised in Southern California, I grew up in a small surf community within the Ventura County Line that nestles against the base of the Santa Monica mountains. I often reflect on growing up in this very special community with great appreciation and awe.
          </p>
          <p class="font-body text-sm text-navy/60 leading-relaxed">
            After 25 years of living in the hills of my beloved Northeast Los Angeles (NELA), and working one on one coaching clients to make therapeutic lifestyle change, I felt the California coast I love so much call me back. In 2022, I decided to take my years of professional experience and blend it with my lifelong interest in skin care, and became a licensed esthetician. 2024 brought me to South Orange County and back to the coastal influence and surf community I had been longing to reconnect with.
          </p>
          <p class="font-body text-sm text-navy/60 leading-relaxed">
            I have always felt very passionate about making a positive difference in the lives of others and am pleased my skin care practice allows me to carry this deeply held intention forward.
          </p>
          <p class="font-body text-sm text-navy/60 leading-relaxed">
            Outside of work, my husband and I enjoy spending time with our two kitties, traveling the world, cooking healthy meals, snow skiing, hiking and paddle boarding. For me, connecting to nature brings a great sense of peace, so I strive to spend time outdoors everyday. On weekends, you will often find me dancing barefoot around the house listening to my vinyl record collection.
          </p>
          <div class="pt-2 flex flex-wrap gap-3">
            {['Licensed Esthetician', 'EcoCert Trained', 'Functional Medicine Health Coach', 'Spray Tan Artist', 'LED Light Therapy Certified'].map(tag => (
              <span class="font-body text-xs text-teal border border-teal/30 rounded-full px-4 py-1.5">
                {tag}
              </span>
            ))}
          </div>
          <div class="pt-2 border-t border-silver">
            <p class="font-body text-sm text-navy font-medium mt-4">Dawn Kratofil</p>
            <p class="font-body text-xs text-navy/50">Founder & Licensed Esthetician</p>
            <a href="mailto:dawn@sageandserumskin.com" class="font-body text-xs text-teal hover:text-navy transition-colors">
              dawn@sageandserumskin.com
            </a>
          </div>
        </div>

      </div>

    </div>
  </main>
</BaseLayout>

<script>
  const slides = document.querySelectorAll('[id^="slide-"]')
  const dots = document.querySelectorAll('.dot')
  let current = 0

  function goTo(index) {
    slides[current].classList.remove('opacity-100')
    slides[current].classList.add('opacity-0')
    dots[current].classList.remove('bg-navy')
    dots[current].classList.add('bg-navy/30')

    current = (index + slides.length) % slides.length

    slides[current].classList.remove('opacity-0')
    slides[current].classList.add('opacity-100')
    dots[current].classList.remove('bg-navy/30')
    dots[current].classList.add('bg-navy')
  }

  document.getElementById('prev')?.addEventListener('click', () => goTo(current - 1))
  document.getElementById('next')?.addEventListener('click', () => goTo(current + 1))

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => goTo(i))
  })
</script>